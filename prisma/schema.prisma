generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UsuarioClienteStatus {
  ativo
  suspenso
  inativo
}

enum CampanhaStatus {
  ativo
  pausado
  finalizado
  sorteado
}

enum RifinhaStatus {
  ativo
  pausado
  finalizado
}

enum StatusPagamento {
  pendente
  pago
  expirado
  cancelado
}

enum CotaStatus {
  disponivel
  reservado
  pago
}

model UsuarioCliente {
  id        String                @id @default(uuid()) @db.Uuid
  nome      String                @db.VarChar(160)
  email     String                @unique @db.VarChar(180)
  whatsapp  String?               @db.VarChar(30)
  senhaHash String                @map("senha_hash") @db.VarChar(255)
  status    UsuarioClienteStatus  @default(ativo)
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")

  campanhas Campanha[]

  @@map("usuarios_clientes")
}

model Administrador {
  id                String   @id @default(uuid()) @db.Uuid
  nome              String   @db.VarChar(160)
  email             String   @unique @db.VarChar(180)
  password          String   @db.VarChar(255)
  whatsapp          String?  @db.VarChar(30)
  pixChave          String?  @map("pix_chave") @db.VarChar(180)
  pixTipo           String?  @map("pix_tipo") @db.VarChar(30)
  telefoneMensagens String?  @map("telefone_mensagens") @db.VarChar(30)
  gatewayPreferido  String?  @map("gateway_preferido") @db.VarChar(30)
  mercadoPagoUserId String?  @map("mercado_pago_user_id") @db.VarChar(80)
  mercadoPagoAccessToken String? @map("mercado_pago_access_token") @db.Text
  mercadoPagoRefreshToken String? @map("mercado_pago_refresh_token") @db.Text
  mercadoPagoTokenExpiresAt DateTime? @map("mercado_pago_token_expires_at")
  mercadoPagoConnectedAt DateTime? @map("mercado_pago_connected_at")
  asaasApiKey       String?  @map("asaas_api_key") @db.Text
  asaasEnvironment  String?  @map("asaas_environment") @db.VarChar(20)
  asaasConnectedAt  DateTime? @map("asaas_connected_at")
  asaasAccountId    String?  @map("asaas_account_id") @db.VarChar(120)
  asaasWalletId     String?  @map("asaas_wallet_id") @db.VarChar(120)
  asaasSplitPercentual Decimal? @map("asaas_split_percentual") @db.Decimal(5, 2)
  documento         String?  @db.VarChar(20)
  nascimento        DateTime?
  faturamentoMensal Decimal? @map("faturamento_mensal") @db.Decimal(12, 2)
  cep               String?  @db.VarChar(12)
  endereco          String?  @db.VarChar(180)
  enderecoNumero    String?  @map("endereco_numero") @db.VarChar(40)
  bairro            String?  @db.VarChar(120)
  complemento       String?  @db.VarChar(120)
  tipoEmpresa       String?  @map("tipo_empresa") @db.VarChar(80)
  termosUsoAceitoEm DateTime? @map("termos_uso_aceito_em")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  campanhas Campanha[]
  saques    Saque[]

  @@map("administradores")
}

model Saque {
  id              String   @id @default(uuid()) @db.Uuid
  administradorId String   @map("admin_id") @db.Uuid
  valor           Decimal  @db.Decimal(10, 2)
  pixChave        String   @map("pix_chave") @db.VarChar(180)
  pixTipo         String   @map("pix_tipo") @db.VarChar(30)
  status          String   @default("pendente") @db.VarChar(40)
  asaasTransferId String?  @map("asaas_transfer_id") @db.VarChar(120)
  payload         Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  administrador Administrador @relation(fields: [administradorId], references: [id], onDelete: Cascade)

  @@index([administradorId])
  @@index([status])
  @@map("saques")
}

model Campanha {
  id               String          @id @default(uuid()) @db.Uuid
  usuarioClienteId String          @map("usuario_id") @db.Uuid
  administradorId  String?         @map("admin_id") @db.Uuid
  titulo           String          @db.VarChar(180)
  slug             String          @unique @db.VarChar(180)
  descricao        String?         @db.Text
  regulamento      String?         @db.Text
  valorCota        Decimal         @map("valor_cota") @db.Decimal(10, 2)
  totalCotas       Int             @map("total_cotas")
  status           CampanhaStatus  @default(pausado)
  imagemUrl        String?         @map("imagem_url") @db.Text
  dataSorteio      DateTime?       @map("data_sorteio")
  metadata         Json            @default("{}")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  usuarioCliente UsuarioCliente @relation(fields: [usuarioClienteId], references: [id], onDelete: Cascade)
  administrador  Administrador? @relation(fields: [administradorId], references: [id], onDelete: SetNull)
  rifinhas       Rifinha[]
  pedidos        Pedido[]
  cotas          CotaCampanha[]

  @@index([usuarioClienteId])
  @@index([administradorId])
  @@index([status])
  @@map("campanhas")
}

model Rifinha {
  id          String        @id @default(uuid()) @db.Uuid
  campanhaId  String        @map("campanha_id") @db.Uuid
  titulo      String        @db.VarChar(180)
  descricao   String?       @db.Text
  valorCota   Decimal       @map("valor_cota") @db.Decimal(10, 2)
  totalCotas  Int           @map("total_cotas")
  status      RifinhaStatus @default(ativo)
  imagemUrl   String?       @map("imagem_url") @db.Text
  ordem       Int           @default(0)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  campanha Campanha @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  pedidos  Pedido[]

  @@index([campanhaId])
  @@index([status])
  @@map("rifinhas")
}

model Pedido {
  id                String          @id @default(uuid()) @db.Uuid
  campanhaId        String          @map("campanha_id") @db.Uuid
  rifinhaId         String?         @map("rifinha_id") @db.Uuid
  compradorNome     String          @map("nome_comprador") @db.VarChar(160)
  compradorWhatsapp String          @map("whatsapp_comprador") @db.VarChar(30)
  compradorEmail    String?         @map("comprador_email") @db.VarChar(180)
  cotasReservadas   Int[]           @map("cotas")
  statusPagamento   StatusPagamento @default(pendente) @map("status_pagamento")
  valorTotal        Decimal         @map("valor_total") @db.Decimal(10, 2)
  pixCopiaCola      String?         @map("pix_copia_cola") @db.Text
  pixQrCode         String?         @map("pix_qr_code") @db.Text
  gatewayProvider   String?         @map("gateway_provider") @db.VarChar(40)
  gatewayPaymentId  String?         @unique @map("gateway_payment_id") @db.VarChar(120)
  gatewayPayload    Json?           @map("gateway_payload")
  expiresAt         DateTime?       @map("expires_at")
  paidAt            DateTime?       @map("paid_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  campanha Campanha @relation(fields: [campanhaId], references: [id], onDelete: Restrict)
  rifinha  Rifinha? @relation(fields: [rifinhaId], references: [id], onDelete: SetNull)
  cotas    CotaCampanha[]

  @@index([campanhaId])
  @@index([rifinhaId])
  @@index([statusPagamento])
  @@index([gatewayProvider])
  @@map("pedidos")
}

model CotaCampanha {
  id         String     @id @default(uuid()) @db.Uuid
  campanhaId String     @map("campanha_id") @db.Uuid
  pedidoId   String?    @map("pedido_id") @db.Uuid
  numero     Int
  status     CotaStatus @default(disponivel)
  reservedAt DateTime?  @map("reserved_at")
  paidAt     DateTime?  @map("paid_at")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  campanha Campanha @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  pedido   Pedido?  @relation(fields: [pedidoId], references: [id], onDelete: SetNull)

  @@unique([campanhaId, numero])
  @@index([campanhaId, status])
  @@index([pedidoId])
  @@map("cotas_campanha")
}
